+  [[ "$output" == *'"decision": "approve"'* ]]
+}
+
+@test "approve: non-Bash tool" {
+  run run_hook Edit "/tmp/foo.txt"
+  [[ "$output" == *'"decision": "approve"'* ]]
+}
+
+@test "approve: empty command" {
+  run run_hook Bash ""
+  [[ "$output" == *'"decision": "approve"'* ]]
+}
